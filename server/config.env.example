# 复制此文件为 config.env 并填写真实值，然后 chmod 600 config.env

# Gmail 账号（全邮箱地址）
GMAIL_USER=redclawcecilia@gmail.com

# Gmail App Password（16位，不是 Google 登录密码）
# 获取：https://myaccount.google.com/apppasswords（需先开 2FA）
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# GitHub 访问凭证
GITHUB_USER=redclawcecilia-tech
GITHUB_REPO=family
# 需要 repo 权限的 Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# 本地 git 仓库路径（绝对路径），通常是 clone 下来的 family 仓库所在目录
REPO_PATH=/home/yourname/family

# Web 服务监听端口（默认 8080，规避国内云 80/443 端口的 ICP 备案要求）
# 父母访问的 URL 会变成 http://<服务器IP>:8080/
# 如已完成 ICP 备案可改回 80（URL 更简洁，不带端口号）
WEB_PORT=8080
WEB_HOST=0.0.0.0
