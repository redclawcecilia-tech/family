# 复制此文件为 config.env 并填写真实值，然后 chmod 600 config.env

# ====== 邮箱 IMAP 配置 ======
# IMAP 服务器地址（网易邮箱默认如下，也可换成 Gmail 等）
#   163邮箱: imap.163.com
#   126邮箱: imap.126.com
#   yeah.net: imap.yeah.net
#   Gmail:   imap.gmail.com（国内需配代理）
IMAP_SERVER=imap.163.com
IMAP_PORT=993

# 邮箱账号（完整地址）
IMAP_USER=your_email@163.com

# 邮箱授权码（不是登录密码！）
# 网易邮箱获取：设置 → POP3/SMTP/IMAP → 开启 IMAP → 生成授权码
# Gmail 获取：https://myaccount.google.com/apppasswords（需先开 2FA）
IMAP_PASSWORD=your_authorization_code

# ====== SOCKS5 代理（可选，国内用 Gmail 时必填）======
# 网易邮箱在国内直连，以下留空即可
# Gmail 用户需要配置代理，例如本地 Clash: 127.0.0.1:7890
IMAP_PROXY_HOST=
IMAP_PROXY_PORT=
IMAP_PROXY_USERNAME=
IMAP_PROXY_PASSWORD=

# ====== GitHub 配置 ======
GITHUB_USER=redclawcecilia-tech
GITHUB_REPO=family
# 需要 repo 权限的 Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# ====== 本地仓库路径 ======
REPO_PATH=/home/yourname/family

# ====== Web 服务 ======
WEB_PORT=8080
WEB_HOST=0.0.0.0
